---
import CopyEmailButton from "./CopyEmailButton";
import { CONTACT, SHOW_RESUME } from "../lib/site";
---

<section id="contact" class="mx-auto max-w-5xl scroll-mt-20 px-6 py-20 sm:py-28">
  <h2 class="font-mono text-xs uppercase tracking-[0.15em] text-signal">
    Contact
  </h2>
  <h3 class="mt-3 font-display text-3xl font-semibold text-paper sm:text-4xl">
    Let's talk about the role.
  </h3>
  <p class="mt-4 max-w-xl text-muted">
    {CONTACT.availability} and based on the {CONTACT.location}.{" "}
    {CONTACT.workPreference}. Email is the fastest way to reach me.
  </p>

  <div class="mt-8 flex flex-wrap items-center gap-4">
    <CopyEmailButton client:idle email={CONTACT.email} />
    <a
      href={CONTACT.github}
      class="font-mono text-sm text-muted transition-colors hover:text-trace"
    >
      {CONTACT.githubLabel}
    </a>
    <a
      href={CONTACT.linkedin}
      class="font-mono text-sm text-muted transition-colors hover:text-trace"
    >
      {CONTACT.linkedinLabel}
    </a>
    {
      SHOW_RESUME && (
        <a
          href={CONTACT.resumeHref}
          class="font-mono text-sm text-muted transition-colors hover:text-trace"
        >
          Download résumé
        </a>
      )
    }
  </div>
</section>
