---
import { NAV_LINKS } from "../lib/site";
import CommandPaletteTrigger from "./CommandPaletteTrigger.astro";
---

<header
  class="sticky top-0 z-40 border-b border-panel-line bg-ink/90 backdrop-blur"
>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-6 py-4"
  >
    <a href="/" class="group flex items-baseline gap-2">
      <span class="font-mono text-xs text-signal">●</span>
      <span class="font-mono text-sm uppercase tracking-[0.15em] text-paper">
        Adam Tunchay
      </span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-6 md:flex">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class="font-mono text-xs uppercase tracking-[0.1em] text-muted transition-colors hover:text-trace"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <CommandPaletteTrigger />
  </div>
</header>
