---
import { SKILLS } from "../lib/site";
---

<section
  id="skills"
  class="mx-auto max-w-5xl scroll-mt-20 border-t border-panel-line px-6 py-20 sm:py-28"
>
  <h2 class="font-mono text-xs uppercase tracking-[0.15em] text-signal">
    Skills
  </h2>
  <p
    class="mt-3 max-w-2xl font-display text-3xl font-semibold text-paper sm:text-4xl"
  >
    What I actually build with.
  </p>

  <dl class="mt-12 grid gap-x-8 gap-y-10 sm:grid-cols-3">
    {
      SKILLS.map((group) => (
        <div>
          <dt class="font-mono text-xs uppercase tracking-[0.1em] text-muted">
            {group.label}
          </dt>
          <dd class="mt-3 leading-relaxed text-paper">
            {group.items.join(", ")}
          </dd>
        </div>
      ))
    }
  </dl>
</section>
